{
  "name": "geg-aaa-clean",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:*",
    "dev:backend": "npm --workspace @geg/backend run dev",
    "dev:frontend": "npm --workspace @geg/frontend run dev",
    "test": "npm --workspace @geg/shared run test",
    "build": "npm --workspace @geg/frontend run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
